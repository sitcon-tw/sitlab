PROJECT_TEMPLATE_ENV=local
PROJECT_TEMPLATE_SERVICE_NAME=project-template-controller
PROJECT_TEMPLATE_VERSION=0.1.0
PROJECT_TEMPLATE_HTTP_ADDR=:8080
PROJECT_TEMPLATE_WEB_DIR=
PROJECT_TEMPLATE_DATABASE_URL=postgres://project:project@localhost:5432/project?sslmode=disable
PROJECT_TEMPLATE_LOG_LEVEL=info
PROJECT_TEMPLATE_SESSION_COOKIE_NAME=project_template_session
PROJECT_TEMPLATE_SESSION_COOKIE_SECURE=false
PROJECT_TEMPLATE_SESSION_HASH_KEY=local-development-session-hash-key-change-me
PROJECT_TEMPLATE_SESSION_IDLE_TTL=12h
PROJECT_TEMPLATE_SESSION_ABSOLUTE_TTL=168h
PROJECT_TEMPLATE_CSRF_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
PROJECT_TEMPLATE_REQUEST_TIMEOUT=15s
PROJECT_TEMPLATE_SHUTDOWN_TIMEOUT=10s
PROJECT_TEMPLATE_OTEL_TRACES_ENDPOINT=
