SITCON_BOARD_ENV=local
SITCON_BOARD_SERVICE_NAME=sitcon-board-controller
SITCON_BOARD_VERSION=0.1.0
SITCON_BOARD_HTTP_ADDR=:8080
SITCON_BOARD_WEB_DIR=
SITCON_BOARD_DATABASE_URL=postgres://sitcon:sitcon@localhost:5432/sitcon_board?sslmode=disable
SITCON_BOARD_LOG_LEVEL=info
SITCON_BOARD_SESSION_HASH_KEY=local-development-session-hash-key-change-me
SITCON_BOARD_OAUTH_STATE_CIPHER_KEY=local-development-oauth-cipher-key-change-me
SITCON_BOARD_SESSION_COOKIE_SECURE=false
SITCON_BOARD_GITLAB_BASE_URL=https://gitlab.com
SITCON_BOARD_GITLAB_CLIENT_ID=
SITCON_BOARD_GITLAB_CLIENT_SECRET=
SITCON_BOARD_GITLAB_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/gitlab/callback
SITCON_BOARD_GITLAB_PROJECT_ACCESS_TOKEN=
SITCON_BOARD_GITLAB_BRANCH=main
SITCON_BOARD_CSRF_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
SITCON_BOARD_DIRECTORY_SYNC_INTERVAL=5m
SITCON_BOARD_BOARD_SYNC_INTERVAL=30s
SITCON_BOARD_OPERATION_POLL_INTERVAL=500ms
SITCON_BOARD_REQUEST_TIMEOUT=15s
SITCON_BOARD_SHUTDOWN_TIMEOUT=10s
SITCON_BOARD_OTEL_TRACES_ENDPOINT=
