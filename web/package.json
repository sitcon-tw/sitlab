{
	"name": "@project-template/web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"prebuild": "pnpm --filter @project-template/ui build",
		"build": "vite build",
		"dev": "vite",
		"generate:api-types": "openapi-typescript ../docs/public/openapi.json -o src/shared/api/openapi.d.ts",
		"lint": "eslint .",
		"preview": "vite preview",
		"pretest": "pnpm --filter @project-template/ui build",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:list": "playwright test --list",
		"test:watch": "vitest",
		"pretypecheck": "pnpm --filter @project-template/ui build",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@project-template/ui": "workspace:*",
		"@tanstack/react-query": "^5.90.20",
		"lucide-react": "^0.468.0",
		"openapi-fetch": "^0.15.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.13.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.0",
		"eslint": "^10.0.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globals": "^17.7.0",
		"jsdom": "^27.4.0",
		"openapi-typescript": "^7.10.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.0.0",
		"vitest": "^4.0.18",
		"vitest-axe": "^0.1.0"
	}
}
