{
	"name": "@project-template/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsp compile . --warn-as-error --no-emit",
		"check": "tsp compile . --warn-as-error --no-emit",
		"format": "tsp format \"**/*.tsp\" && prettier --write .",
		"format:check": "tsp format \"**/*.tsp\" --check && prettier --check .",
		"format:check:tsp": "tsp format \"**/*.tsp\" --check",
		"format:tsp": "tsp format \"**/*.tsp\"",
		"generate:openapi": "tsp compile . --warn-as-error",
		"lint": "tsp compile . --warn-as-error --no-emit"
	},
	"devDependencies": {
		"@typespec/compiler": "1.7.0",
		"@typespec/http": "1.7.0",
		"@typespec/openapi": "1.7.0",
		"@typespec/openapi3": "1.7.0",
		"prettier": "^3.8.4"
	},
	"tspMain": "main.tsp"
}
