#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

mapfile -d '' staged < <(git diff --cached --name-only --diff-filter=ACMR -z)
((${#staged[@]} > 0)) || exit 0

frontend_files=()
go_files=()
api_changed=false

for file in "${staged[@]}"; do
	case "$file" in
		*.astro | *.css | *.html | *.js | *.json | *.jsx | *.md | *.mdx | *.mjs | *.ts | *.tsx | *.yaml | *.yml) frontend_files+=("$file") ;;
		*.go) go_files+=("$file") ;;
	esac
	[[ "$file" == api/* ]] && api_changed=true
done

if ((${#frontend_files[@]} > 0)); then
	pnpm exec prettier --write -- "${frontend_files[@]}"
	git add -- "${frontend_files[@]}"
fi

if ((${#go_files[@]} > 0)); then
	gofmt -w -- "${go_files[@]}"
	git add -- "${go_files[@]}"
fi

if [[ "$api_changed" == true ]]; then
	pnpm --filter @project-template/api check
fi
