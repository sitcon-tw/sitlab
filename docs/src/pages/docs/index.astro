---
import { getEntry, render } from "astro:content";
import BaseAwareLink from "../../layouts/BaseAwareLink.astro";
import DocLayout from "../../layouts/DocLayout.astro";

const entry = await getEntry("docs", "index");
if (!entry) throw new Error("Missing docs index entry");
const { Content, headings } = await render(entry);
---

<DocLayout title={entry.data.title} description={entry.data.description} headings={headings}>
	<Content components={{ a: BaseAwareLink }} />
</DocLayout>
