---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { hrefForDocId } from "../../data/navigation";
import BaseAwareLink from "../../layouts/BaseAwareLink.astro";
import DocLayout from "../../layouts/DocLayout.astro";

export async function getStaticPaths() {
	const entries = await getCollection("docs", (entry) => !entry.data.draft && entry.id !== "index");
	return entries.map((entry) => ({
		params: {
			slug: hrefForDocId(entry.id)
				.replace(/^\/docs\//, "")
				.replace(/\/$/, "")
		},
		props: { entry }
	}));
}

interface Props {
	entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<DocLayout title={entry.data.title} description={entry.data.description} headings={headings}>
	<Content components={{ a: BaseAwareLink }} />
</DocLayout>
