{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"allowImportingTsExtensions": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"outDir": "dist",
		"rootDir": "src",
		"types": []
	},
	"include": ["src/index.ts", "src/components/**/*.tsx", "src/lib/**/*.ts"],
	"exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/stories"]
}
