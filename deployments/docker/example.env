# Local quickstart values. Replace every change-me value before production.
PROJECT_TEMPLATE_ENV=local
PROJECT_TEMPLATE_VERSION=local
PROJECT_TEMPLATE_PORT=3000
PROJECT_TEMPLATE_LOG_LEVEL=info
PROJECT_TEMPLATE_IMAGE=project-template

PROJECT_TEMPLATE_DATABASE_PASSWORD=change-me-database-password
PROJECT_TEMPLATE_SESSION_HASH_KEY=change-me-at-least-32-random-bytes
PROJECT_TEMPLATE_SESSION_COOKIE_NAME=project_template_session
PROJECT_TEMPLATE_SESSION_COOKIE_SECURE=false
PROJECT_TEMPLATE_CSRF_ALLOWED_ORIGINS=http://localhost:3000

# Leave empty to disable trace export. The observability compose overlay sets this.
PROJECT_TEMPLATE_OTEL_TRACES_ENDPOINT=
