# Local quickstart values. Replace every change-me value before production.
SITCON_BOARD_ENV=local
SITCON_BOARD_VERSION=local
SITCON_BOARD_PORT=3000
SITCON_BOARD_LOG_LEVEL=info
SITCON_BOARD_IMAGE=sitcon-board

SITCON_BOARD_DATABASE_PASSWORD=change-me-database-password
SITCON_BOARD_SESSION_HASH_KEY=change-me-at-least-32-random-bytes
SITCON_BOARD_OAUTH_STATE_CIPHER_KEY=change-me-another-32-random-bytes
SITCON_BOARD_SESSION_COOKIE_SECURE=false
SITCON_BOARD_CSRF_ALLOWED_ORIGINS=http://localhost:3000

SITCON_BOARD_GITLAB_CLIENT_ID=change-me
SITCON_BOARD_GITLAB_CLIENT_SECRET=change-me
SITCON_BOARD_GITLAB_OAUTH_REDIRECT_URL=http://localhost:3000/api/v1/auth/gitlab/callback
SITCON_BOARD_GITLAB_PROJECT_ACCESS_TOKEN=change-me

# Leave empty to disable trace export. The observability compose overlay sets this.
SITCON_BOARD_OTEL_TRACES_ENDPOINT=
