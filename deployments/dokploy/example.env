# Public HTTPS origin without a trailing slash.
SITCON_BOARD_PUBLIC_URL=https://board.example.com

# Use a release tag or commit SHA to identify the deployed image.
SITCON_BOARD_VERSION=latest
SITCON_BOARD_REVISION=main
SITCON_BOARD_LOG_LEVEL=info

# Generate URL-safe values with: openssl rand -hex 32
SITCON_BOARD_DATABASE_PASSWORD=change-me-url-safe-database-password
SITCON_BOARD_SESSION_HASH_KEY=change-me-at-least-32-random-bytes
SITCON_BOARD_OAUTH_STATE_CIPHER_KEY=change-me-another-32-random-bytes

# GitLab OAuth application and sitcon-tw/2027 project access token.
SITCON_BOARD_GITLAB_CLIENT_ID=change-me
SITCON_BOARD_GITLAB_CLIENT_SECRET=change-me
SITCON_BOARD_GITLAB_PROJECT_ACCESS_TOKEN=change-me

# Optional overrides.
SITCON_BOARD_DIRECTORY_SYNC_INTERVAL=5m
SITCON_BOARD_BOARD_SYNC_INTERVAL=30s
SITCON_BOARD_OPERATION_POLL_INTERVAL=500ms
SITCON_BOARD_REQUEST_TIMEOUT=15s
SITCON_BOARD_SHUTDOWN_TIMEOUT=10s
SITCON_BOARD_OTEL_TRACES_ENDPOINT=
